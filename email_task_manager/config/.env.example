# Flask Settings
FLASK_APP=run.py
FLASK_ENV=development  # Change to 'production' for production deployment
SECRET_KEY=your_secret_key_here  # Change this to a random string in production

# Database Settings
# SQLite (default)
DATABASE_URL=sqlite:///instance/app.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/email_task_manager

# Email Settings
GMAIL_API_CREDENTIALS=credentials.json
GMAIL_API_TOKEN=token.json
EMAIL_CHECK_INTERVAL=300  # in seconds

# NLP Settings
SPACY_MODEL=en_core_web_sm
USE_OPENAI=False
OPENAI_API_KEY=your_openai_api_key  # Only needed if USE_OPENAI=True

# Printer Settings
DEFAULT_PRINTER=  # Leave empty to use system default
RECEIPT_WIDTH=40  # characters
PRINT_HEADER=Task Receipt
PRINT_FOOTER=Thank you!

# Task Settings
DEFAULT_TASK_PRIORITY=Medium  # Low, Medium, High, Urgent

# Server Settings
HOST=0.0.0.0
PORT=5000